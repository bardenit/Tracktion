# ── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vehicle_user:vehicle_password@postgres:5432/vehicle_tracker
JWT_SECRET_KEY=your-super-secret-key-min-32-characters

# ── Optional: AI / OCR ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Optional: Storage (default is local) ─────────────────────────────────────
# Leave STORAGE_TYPE unset (or omit entirely) to use local file storage.
# Set to "s3" for S3-compatible (AWS S3, Backblaze B2, MinIO, etc.)
# Set to "webdav" for WebDAV-compatible storage.

# S3-compatible example (Backblaze B2):
#STORAGE_TYPE=s3
#STORAGE_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#STORAGE_S3_BUCKET=your-bucket-name
#STORAGE_S3_REGION=us-west-004
#STORAGE_S3_ACCESS_KEY=your-key-id
#STORAGE_S3_SECRET_KEY=your-application-key

# WebDAV example:
#STORAGE_TYPE=webdav
#STORAGE_WEBDAV_URL=https://your-webdav-host
#STORAGE_WEBDAV_USERNAME=your-username
#STORAGE_WEBDAV_PASSWORD=your-password
#STORAGE_WEBDAV_PATH=/tracktion

# ── Optional: App settings ────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
